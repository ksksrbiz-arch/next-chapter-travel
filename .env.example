# Neon Postgres connection string.
# On Vercel: injected automatically by the Neon native integration
# (Marketplace > Neon > Install). Locally: copy from the Neon dashboard.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Where new-lead notifications go (wire to Resend/MailerLite later)
LEAD_NOTIFICATION_EMAIL=hello@nextchaptertravel.com
